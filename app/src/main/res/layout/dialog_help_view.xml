        </TableLayout>
        <TextView
            android:id="@+id/helpCarbsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Kolhydrater, 45-60% av de kalorier man får i sig under en dag bör komma från Kostfibrer, och Fritt socker bör ej överstiga 10%."
            android:textStyle="bold"
            android:textSize="15sp"/>
        <TableLayout
            android:id="@+id/dailyCarbsWoman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:shrinkColumns="*">
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:padding="8dp"
                    android:text="Kvinnor"
                    android:textStyle="bold"/>
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:padding="8dp"
                    android:text="Kostfibrer"/>
                <TextView
                    android:padding="8dp"
                    android:text="25g"/>
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:padding="8dp"
                    android:text="Fritt socker"/>
                <TextView
                    android:padding="8dp"
                    android:text="5g (Men bör undvikas)"/>
            </TableRow>
        </TableLayout>
