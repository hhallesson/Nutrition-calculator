            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:stretchColumns="*"
            android:shrinkColumns="*">
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="Män"
                    android:textStyle="bold" />

