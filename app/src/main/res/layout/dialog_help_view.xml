                    android:padding="8dp"
                    android:text="25-50 år" />

                <TextView
                    android:padding="8dp"
                    android:text="2400" />

                <TextView
                    android:padding="8dp"
                    android:text="2700" />

                <TextView
                    android:padding="8dp"
                    android:text="3000" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="51-70 år" />

                <TextView
                    android:padding="8dp"
                    android:text="2200" />

                <TextView
                    android:padding="8dp"
                    android:text="2500" />

                <TextView
                    android:padding="8dp"
                    android:text="2800" />
