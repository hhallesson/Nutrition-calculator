        <TextView
            android:id="@+id/helpFatTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Fett, ungefär en tredjedel av de kalorier man får i sig på en dag bör komma från fett."
            android:textStyle="bold"
            android:textSize="15sp"/>
        <TableLayout
            android:id="@+id/dailyFatWoman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
