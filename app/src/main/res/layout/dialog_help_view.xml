                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="Kvinnor"
                    android:textStyle="bold" />

                <TextView
                    android:padding="8dp"
                    android:text="Låg"
                    android:textStyle="bold" />

                <TextView
                    android:padding="8dp"
                    android:text="Medel"
                    android:textStyle="bold" />

                <TextView
                    android:padding="8dp"
                    android:text="Hög"
                    android:textStyle="bold" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="18-24 år" />

                <TextView
                    android:padding="8dp"
                    android:text="2000" />

                <TextView
                    android:padding="8dp"
                    android:text="2200" />

                <TextView
                    android:padding="8dp"
                    android:text="2500" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="25-50 år" />

                <TextView
                    android:padding="8dp"
                    android:text="1900" />

                <TextView
                    android:padding="8dp"
                    android:text="2200" />

                <TextView
                    android:padding="8dp"
                    android:text="2400" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="51-70 år" />

                <TextView
                    android:padding="8dp"
                    android:text="1700" />

                <TextView
                    android:padding="8dp"
                    android:text="2000" />

                <TextView
                    android:padding="8dp"
                    android:text="2200" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:padding="8dp"
                    android:text="över 70 år" />

                <TextView
                    android:padding="8dp"
                    android:text="1700" />

                <TextView
                    android:padding="8dp"
                    android:text="2000" />

                <TextView
                    android:padding="8dp"
